# Campus Faculty Connector - Environment Variables Template
# Copy this file to .env and fill in your actual values

# Campus Credentials (KEEP THESE SECRET!)
CAMPUS_USER=your_student_id_or_email
CAMPUS_PASSWORD=your_campus_password
CAMPUS_URL=https://campus.yourfaculty.edu

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
ENVIRONMENT=development

# MCP Configuration
MCP_TRANSPORT=sse
